#!/bin/bash

# Storefront Check Pre-commit Hook
# Add this to .git/hooks/pre-commit

echo "Running storefront code validation..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(tsx|jsx)$')

if [ -z "$STAGED_FILES" ]; then
  echo "No TSX/JSX files staged, skipping validation"
  exit 0
fi

# Run validation on staged files
RESULT=$(npx storefront-check $STAGED_FILES 2>&1)
EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
  echo "✅ Code validation passed"
  exit 0
else
  echo "$RESULT"
  echo ""
  echo "❌ Code validation failed. Please fix the errors above."
  exit 1
fi
